---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="AM Clients" description="Direct-link client presentations.">
  <main class="home-shell">
    <section class="home-card">
      <p class="home-card__eyebrow">AM Clients</p>
      <h1>Direct-link presentation viewer</h1>
      <p>
        This root page stays intentionally quiet. Open your project with the link you were shared.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .home-shell {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }

  .home-card {
    width: min(100%, 38rem);
    padding: 1.5rem;
    border: 1px solid var(--line-soft);
    border-radius: 1.5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(9, 9, 10, 0.78);
    box-shadow: var(--shadow-soft);
  }

  .home-card__eyebrow {
    margin: 0;
    color: var(--ink-1);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.4rem 0 0.9rem;
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: -0.05em;
  }

  p {
    margin: 0;
    color: var(--ink-1);
    line-height: 1.6;
  }

</style>
