---
import type { ImageMetadata } from "astro";
import Moon from "phosphor-astro/Moon.astro";
import Sun from "phosphor-astro/Sun.astro";

type Wall = {
  image: ImageMetadata;
  alt: string;
  label?: string;
};

type Props = {
  title: string;
  description?: string;
  walls: Wall[];
};

const { title, description, walls } = Astro.props;
---

<main class="room-shell">
  <section
    class="room-loop"
    data-room-loop
    data-current-index="0"
    data-slide-count={walls.length}
    tabindex="0"
    aria-label={`${title} interactive room viewer`}
  >
    <div class="room-loop__topline">
      <div>
        <p class="room-loop__eyebrow">Client presentation</p>
        <h1>{title}</h1>
      </div>

      <div class="room-loop__meta">
        <button
          type="button"
          class="room-loop__theme-toggle"
          data-theme-toggle
          aria-label="Switch to dark mode"
          aria-pressed="false"
        >
          <span class="room-loop__sr-only" data-theme-toggle-label>Dark mode</span>
          <span class="room-loop__theme-icon" data-theme-icon="moon" aria-hidden="true">
            <Moon width={18} height={18} />
          </span>
          <span class="room-loop__theme-icon" data-theme-icon="sun" aria-hidden="true">
            <Sun width={18} height={18} />
          </span>
        </button>
        {description && <p>{description}</p>}
        <p class="room-loop__hint">Drag, swipe, scroll, or use arrow keys.</p>
      </div>
    </div>

    <div class="room-loop__viewport" data-room-loop-viewport>
      <div class="room-loop__container">
        {
          walls.map((wall, index) => (
            <figure
              class="room-loop__slide"
              data-wall-slide
              data-slide-index={index}
              data-slide-label={wall.label ?? `Wall ${index + 1}`}
            >
              <img
                src={wall.image.src}
                width={wall.image.width}
                height={wall.image.height}
                alt={wall.alt}
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={index === 0 ? "high" : "auto"}
              />
            </figure>
          ))
        }
      </div>
    </div>

    <div class="room-loop__toolbar">
      <p class="room-loop__caption" data-room-loop-caption>1/{walls.length}</p>
      <div class="room-loop__controls">
        <button type="button" data-room-loop-prev aria-label="Previous wall">
          Prev
        </button>
        <button type="button" data-room-loop-next aria-label="Next wall">
          Next
        </button>
      </div>
    </div>
  </section>
</main>

<style>
  .room-shell {
    --shell-padding: 1.25rem;
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: var(--shell-padding);
  }

  .room-loop {
    --wall-height: clamp(14rem, 64svh, 42rem);
    width: min(100%, 100rem);
    height: calc(100svh - (var(--shell-padding) * 2));
    min-height: calc(100svh - (var(--shell-padding) * 2));
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: 1rem;
    padding: 1.1rem;
    border: 1px solid var(--line-soft);
    border-radius: 1.5rem;
    background: var(--bg-0);
    outline: none;
  }

  .room-loop:focus-visible {
    border-color: var(--line-strong);
    outline: 0.15rem solid rgba(61, 52, 39, 0.12);
    outline-offset: 0;
  }

  :root[data-theme="dark"] .room-loop {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(9, 9, 10, 0.72);
  }

  :root[data-theme="dark"] .room-loop:focus-visible {
    outline-color: rgba(255, 255, 255, 0.22);
  }

  .room-loop__topline {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.85rem;
    align-items: end;
    justify-content: space-between;
  }

  .room-loop__topline > :first-child {
    min-width: 0;
  }

  .room-loop__eyebrow,
  .room-loop__hint,
  .room-loop__meta p {
    margin: 0;
    color: var(--ink-1);
  }

  .room-loop__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.72rem;
  }

  h1 {
    margin: 0.15rem 0 0;
    font-size: clamp(1.5rem, 2.6vw, 2.35rem);
    letter-spacing: -0.03em;
  }

  .room-loop__meta {
    display: grid;
    gap: 0.35rem;
    justify-self: end;
    justify-items: end;
    text-align: right;
    max-width: 34rem;
  }

  .room-loop__theme-toggle {
    justify-self: end;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: var(--bg-0);
    color: var(--ink-0);
    padding: 0.58rem;
    min-height: 2.5rem;
    min-width: 2.5rem;
    display: inline-grid;
    place-items: center;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  :root[data-theme="dark"] .room-loop__theme-toggle {
    background: rgba(255, 255, 255, 0.05);
  }

  .room-loop__theme-toggle:hover,
  .room-loop__theme-toggle:focus-visible {
    border-color: var(--line-strong);
    background: var(--bg-0);
    outline: none;
    transform: translateY(-1px);
  }

  :root[data-theme="dark"] .room-loop__theme-toggle:hover,
  :root[data-theme="dark"] .room-loop__theme-toggle:focus-visible {
    background: rgba(255, 255, 255, 0.11);
  }

  .room-loop__theme-icon {
    display: inline-grid;
    place-items: center;
    line-height: 0;
  }

  [data-theme-icon="sun"] {
    display: none;
  }

  :root[data-theme="dark"] [data-theme-icon="moon"] {
    display: none;
  }

  :root[data-theme="dark"] [data-theme-icon="sun"] {
    display: inline-grid;
  }

  .room-loop__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .room-loop__viewport {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--line-soft);
    background: var(--bg-0);
  }

  :root[data-theme="dark"] .room-loop__viewport {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      rgba(0, 0, 0, 0.24);
  }

  .room-loop__container {
    display: flex;
    gap: 1px;
    align-items: stretch;
    height: 100%;
    padding: 0;
  }

  .room-loop__slide {
    flex: 0 0 auto;
    display: flex;
    align-items: stretch;
    gap: 0;
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .room-loop__slide img {
    width: auto;
    height: 100%;
    max-width: none;
    border-radius: 0;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  .room-loop__caption {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-1);
  }

  .room-loop__toolbar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.85rem;
    align-items: center;
  }

  .room-loop__controls {
    display: flex;
    gap: 0.5rem;
  }

  .room-loop__controls button {
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: var(--bg-0);
    color: var(--ink-0);
    min-width: 4.5rem;
    padding: 0.68rem 0.95rem;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .room-loop__controls button:hover,
  .room-loop__controls button:focus-visible {
    background: var(--bg-0);
    border-color: var(--line-strong);
    transform: translateY(-1px);
    outline: none;
  }

  :root[data-theme="dark"] .room-loop__controls button {
    background: rgba(255, 255, 255, 0.05);
  }

  :root[data-theme="dark"] .room-loop__controls button:hover,
  :root[data-theme="dark"] .room-loop__controls button:focus-visible {
    background: rgba(255, 255, 255, 0.11);
  }

  @media (max-width: 44rem) {
    .room-shell {
      --shell-padding: 0.5rem;
    }

    .room-loop {
      --wall-height: clamp(12.5rem, 56svh, 28rem);
      gap: 0.7rem;
      padding: 0.65rem;
      border-radius: 1rem;
    }

    .room-loop__topline {
      gap: 0.55rem;
    }

    .room-loop__eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.14em;
    }

    h1 {
      margin-top: 0.05rem;
      font-size: 1.35rem;
    }

    .room-loop__meta {
      gap: 0.25rem;
      width: min(8.75rem, 34vw);
      max-width: min(8.75rem, 34vw);
    }

    .room-loop__hint,
    .room-loop__caption {
      font-size: 0.82rem;
    }

    .room-loop__theme-toggle {
      min-height: 2.2rem;
      min-width: 2.2rem;
      padding: 0.42rem;
    }

    .room-loop__viewport {
      border-radius: 0.85rem;
    }

    .room-loop__toolbar {
      gap: 0.6rem;
      align-items: center;
    }

    .room-loop__controls {
      gap: 0.35rem;
      flex-shrink: 0;
    }

    .room-loop__controls button {
      min-width: 3.7rem;
      padding: 0.5rem 0.72rem;
      font-size: 0.82rem;
    }
  }

  @media (max-height: 28rem) and (orientation: landscape) {
    .room-shell {
      --shell-padding: 0.4rem;
      align-items: start;
    }

    .room-loop {
      --wall-height: clamp(7rem, 33svh, 9.5rem);
      gap: 0.45rem;
      padding: 0.55rem;
      border-radius: 0.9rem;
    }

    .room-loop__topline {
      gap: 0.35rem;
    }

    .room-loop__eyebrow {
      font-size: 0.58rem;
      letter-spacing: 0.12em;
    }

    h1 {
      margin-top: 0.05rem;
      font-size: 1.375rem;
    }

    .room-loop__meta {
      gap: 0.2rem;
    }

    .room-loop__hint {
      font-size: 0.8125rem;
    }

    .room-loop__theme-toggle {
      min-height: 2.1rem;
      min-width: 2.1rem;
      padding: 0.42rem;
    }

    .room-loop__viewport {
      border-radius: 0.8rem;
    }

    .room-loop__caption {
      font-size: 0.68rem;
    }

    .room-loop__toolbar {
      gap: 0.45rem;
    }

    .room-loop__progress {
      gap: 0.35rem;
    }

    .room-loop__controls {
      gap: 0.35rem;
    }

    .room-loop__controls button {
      min-width: 3.5rem;
      padding: 0.45rem 0.72rem;
      font-size: 0.82rem;
    }
  }
</style>

<script>
  import "../scripts/room-loop";
  import "../scripts/theme-toggle";
</script>
