---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Moon from "phosphor-astro/Moon.astro";
import Sun from "phosphor-astro/Sun.astro";
import House from "phosphor-astro/House.astro";
import Plus from "phosphor-astro/Plus.astro";
import Minus from "phosphor-astro/Minus.astro";
import HandTap from "phosphor-astro/HandTap.astro";
import CaretLeft from "phosphor-astro/CaretLeftBold.astro";
import CaretRight from "phosphor-astro/CaretRightBold.astro";
import ArrowsOut from "phosphor-astro/ArrowsOut.astro";
import ArrowsIn from "phosphor-astro/ArrowsIn.astro";
import XIcon from "phosphor-astro/X.astro";

type ProjectImage = {
  image: ImageMetadata;
  alt: string;
  label?: string;
};

type Props = {
  title: string;
  description?: string;
  walls: ProjectImage[];
  ceiling?: ProjectImage;
};

const { title, description, walls, ceiling } = Astro.props;
const galleryItems = ceiling ? [...walls, ceiling] : walls;
const room3dConfig = {
  title,
  wallHeight: 10,
  walls: walls.map((wall, index) => ({
    id: `wall-${index + 1}`,
    label: wall.label ?? `Wall ${index + 1}`,
    order: index + 1,
    src: wall.image.src,
    width: wall.image.width,
    height: wall.image.height,
  })),
  ceiling: ceiling
    ? {
        id: "ceiling",
        label: ceiling.label ?? "Ceiling",
        src: ceiling.image.src,
        width: ceiling.image.width,
        height: ceiling.image.height,
      }
    : undefined,
};
---

<main data-presentation data-active-view="slider">
  <section
    class="room"
    data-room-loop
    data-current-index="0"
    data-slide-count={walls.length}
    tabindex="0"
    aria-label={`${title} interactive room viewer`}
  >
    <div class="room__menu">
      <div class="room__menu-row">
        <div class="room__mode-buttons" role="group" aria-label="Presentation views">
          <button type="button" class="room__mode-button" data-view-trigger="slider" aria-pressed="true">
            Slider
          </button>
          <button type="button" class="room__mode-button" data-view-trigger="3d" aria-pressed="false">
            3D
          </button>
          <button type="button" class="room__mode-button" data-view-trigger="gallery" aria-pressed="false">
            Gallery
          </button>
        </div>

        <button
          type="button"
          class="room__fullscreen-toggle"
          data-fullscreen-toggle
          aria-label="Enter fullscreen"
        >
          <span class="room__fullscreen-icon" data-fullscreen-icon="enter" aria-hidden="true">
            <ArrowsOut width={20} height={20} />
          </span>
          <span class="room__fullscreen-icon" data-fullscreen-icon="exit" aria-hidden="true">
            <ArrowsIn width={20} height={20} />
          </span>
        </button>

        <button
          type="button"
          class="room__theme-toggle"
          data-theme-toggle
          aria-label="Switch to dark mode"
          aria-pressed="false"
        >
          <span class="room__sr-only" data-theme-toggle-label>Dark mode</span>
          <span class="room__theme-icon" data-theme-icon="moon" aria-hidden="true">
            <Moon width={18} height={18} />
          </span>
          <span class="room__theme-icon" data-theme-icon="sun" aria-hidden="true">
            <Sun width={18} height={18} />
          </span>
        </button>
      </div>
      {description && <p class="room__description">{description}</p>}
    </div>

    <div class="room__viewstack">
      <div class="room__view room__view--slider" data-view-panel="slider">
        <div class="room__slider-inner">
          <div class="room__viewport" data-room-loop-viewport>
            <div class="room__container">
              {
                walls.map((wall, index) => (
                  <figure
                    class="room__slide"
                    data-wall-slide
                    data-slide-index={index}
                    data-slide-label={wall.label ?? `Wall ${index + 1}`}
                  >
                    <Image
                      src={wall.image}
                      alt={wall.alt}
                      format="webp"
                      quality={85}
                      loading={index === 0 ? "eager" : "lazy"}
                      decoding="async"
                      fetchpriority={index === 0 ? "high" : undefined}
                    />
                  </figure>
                ))
              }
            </div>
          </div>

          <div class="room__toolbar">
            <p class="room__caption" data-room-loop-caption>
              1/{walls.length}
            </p>
            <div class="room__controls">
              <button type="button" data-room-loop-prev aria-label="Previous wall">
                <CaretLeft width={16} height={16} />
              </button>
              <button type="button" data-room-loop-next aria-label="Next wall">
                <CaretRight width={16} height={16} />
              </button>
            </div>
          </div>
        </div>
        <p class="room__hint" data-slider-hint>
          <HandTap width={20} height={20} weight="fill" />
          Click and drag
        </p>
      </div>

      <div class="room__view room__view--3d" data-view-panel="3d" hidden>
        <div class="room__three-wrap" data-room-3d>
          <canvas class="room__three-canvas" data-room-3d-canvas aria-label={`3D room view of ${title}`}></canvas>
          <div class="room__three-nav" data-room-3d-nav>
            <div class="room__zoom-group">
              <button type="button" data-room-3d-zoom-in aria-label="Zoom in">
                <Plus width={16} height={16} />
              </button>
              <input
                type="range"
                class="room__zoom-slider"
                data-room-3d-zoom-slider
                min="0"
                max="100"
                value="50"
                orient="vertical"
                aria-label="Zoom level"
              />
              <button type="button" data-room-3d-zoom-out aria-label="Zoom out">
                <Minus width={16} height={16} />
              </button>
            </div>
            <button type="button" data-room-3d-home aria-label="Reset view">
              <House width={16} height={16} />
            </button>
          </div>
          <p class="room__three-hint" data-room-3d-hint>
            <HandTap width={20} height={20} weight="fill" />
            Click and drag
          </p>
          <div class="room__three-loader" data-room-3d-status aria-live="polite">
            <svg class="room__spinner" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="50 20" />
            </svg>
            <span class="room__three-loader-text">Loading room…</span>
          </div>
        </div>
      </div>

      <div class="room__view room__view--gallery" data-view-panel="gallery" hidden>
        <div class="room__gallery" data-gallery-grid>
          <div class="room__gallery-inner">
            {
              galleryItems.map((item, index) => (
                <button
                  type="button"
                  class="room__gallery-item"
                  data-gallery-item
                  data-gallery-src={item.image.src}
                  data-gallery-alt={item.alt}
                  data-gallery-label={item.label ?? `Image ${index + 1}`}
                >
                  <Image
                    src={item.image}
                    alt={item.alt}
                    format="webp"
                    quality={85}
                    loading="lazy"
                    decoding="async"
                  />
                  <span>{item.label ?? `Image ${index + 1}`}</span>
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <footer class="room__heading">
      <p class="room__eyebrow">Client presentation</p>
      <h1>{title}</h1>
    </footer>

    <dialog class="room__lightbox" data-gallery-lightbox>
      <form method="dialog" class="room__lightbox-close-form">
        <button type="submit" class="room__lightbox-close" aria-label="Close image">
          <XIcon width={18} height={18} />
        </button>
      </form>
      <figure class="room__lightbox-figure">
        <img data-gallery-lightbox-image alt="" />
        <figcaption data-gallery-lightbox-caption></figcaption>
      </figure>
      <div class="room__lightbox-nav">
        <button type="button" class="room__lightbox-prev" data-lightbox-prev aria-label="Previous image">
          <CaretLeft width={16} height={16} />
        </button>
        <button type="button" class="room__lightbox-next" data-lightbox-next aria-label="Next image">
          <CaretRight width={16} height={16} />
        </button>
      </div>
    </dialog>

    <script type="application/json" data-room-3d-config is:inline set:html={JSON.stringify(room3dConfig).replaceAll("<", "\\u003c")} />
  </section>
</main>

<style>
  .room {
    --room-inset: 1.1rem;
    --room-max: 80rem;
    width: 100%;
    height: 100dvh;
    min-height: 100dvh;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    background: var(--bg-0);
    outline: none;
    position: relative;
  }

  @media (min-width: 84rem) {
    [data-presentation] {
      display: grid;
      place-items: center;
      min-height: 100dvh;
      padding: 2rem;
    }

    .room {
      max-width: var(--room-max);
      width: 100%;
      height: calc(100dvh - 4rem);
      max-height: 56rem;
      min-height: 0;
      border-radius: 1.25rem;
      box-shadow:
        0 0 0 1px var(--line-soft),
        var(--shadow-soft);
      overflow: hidden;
    }

    .room__heading {
      padding-bottom: 2rem;
    }

    [data-fullscreen] {
      display: block;
      padding: 0;
    }

    [data-fullscreen] .room {
      max-width: none;
      height: 100dvh;
      max-height: none;
      margin: 0;
      border-radius: 0;
      box-shadow: none;
    }

    [data-fullscreen] .room__heading {
      padding-bottom: 1.4rem;
    }
  }

  .room:focus-visible {
    outline: none;
  }

  :root[data-theme="dark"] .room {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(9, 9, 10, 0.72);
  }

  .room__menu {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    z-index: 5;
    display: grid;
    gap: 0.35rem;
    pointer-events: auto;
  }

  .room__menu-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: flex-end;
  }

  .room__heading {
    padding: 0.9rem var(--room-inset) 1.4rem;
    box-shadow: inset 0 1px 0 0 var(--line-soft);
    background: var(--bg-0);
  }

  :root[data-theme="dark"] .room__heading {
    background: rgba(15, 15, 17, 0.95);
    box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
  }

  .room__eyebrow,
  .room__description,
  .room__gallery-item span {
    margin: 0;
    color: var(--ink-1);
  }

  .room__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.75rem;
  }

  h1 {
    margin: 0.1rem 0 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
  }

  .room__mode-buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .room__mode-button,
  .room__theme-toggle,
  .room__fullscreen-toggle,
  .room__controls button,
  .room__three-nav button,
  .room__lightbox-close {
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: var(--bg-0);
    color: var(--ink-0);
    font: inherit;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .room__mode-button {
    border-color: var(--line-soft);
    padding: 0.58rem 0.9rem;
    min-height: 2.4rem;
    display: inline-grid;
    place-items: center;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .room__theme-toggle {
    justify-self: start;
    padding: 0.58rem;
    min-height: 2.5rem;
    min-width: 2.5rem;
    display: inline-grid;
    place-items: center;
  }

  .room__fullscreen-toggle {
    display: none;
  }

  @media (min-width: 48rem) {
    .room__fullscreen-toggle {
      justify-self: start;
      padding: 0.58rem;
      min-height: 2.5rem;
      min-width: 2.5rem;
      display: inline-grid;
      place-items: center;
    }
  }

  .room__fullscreen-icon[data-fullscreen-icon="exit"] {
    display: none;
  }

  [data-fullscreen] .room__fullscreen-icon[data-fullscreen-icon="enter"] {
    display: none;
  }

  [data-fullscreen] .room__fullscreen-icon[data-fullscreen-icon="exit"] {
    display: inline;
  }

  :root[data-theme="dark"] .room__mode-button,
  :root[data-theme="dark"] .room__theme-toggle,
  :root[data-theme="dark"] .room__fullscreen-toggle,
  :root[data-theme="dark"] .room__controls button,
  :root[data-theme="dark"] .room__lightbox-close {
    background: var(--bg-1);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .room__three-nav button {
    background: rgba(252, 251, 248, 0.72);
    border-color: var(--line-soft);
  }

  :root[data-theme="dark"] .room__three-nav button {
    background: rgba(15, 15, 17, 0.72);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .room__mode-button:hover,
  .room__theme-toggle:hover,
  .room__fullscreen-toggle:hover,
  .room__controls button:hover,
  .room__three-nav button:hover,
  .room__lightbox-close:hover {
    border-color: var(--line-strong);
    outline: none;
  }

  .room__mode-button:focus-visible,
  .room__theme-toggle:focus-visible,
  .room__fullscreen-toggle:focus-visible,
  .room__controls button:focus-visible,
  .room__three-nav button:focus-visible,
  .room__lightbox-close:focus-visible {
    border-color: var(--line-strong);
    outline: 2px solid var(--ink-1);
    outline-offset: 2px;
  }

  :root[data-theme="dark"] .room__mode-button:hover,
  :root[data-theme="dark"] .room__mode-button:focus-visible,
  :root[data-theme="dark"] .room__theme-toggle:hover,
  :root[data-theme="dark"] .room__theme-toggle:focus-visible,
  :root[data-theme="dark"] .room__fullscreen-toggle:hover,
  :root[data-theme="dark"] .room__fullscreen-toggle:focus-visible,
  :root[data-theme="dark"] .room__controls button:hover,
  :root[data-theme="dark"] .room__controls button:focus-visible,
  :root[data-theme="dark"] .room__lightbox-close:hover,
  :root[data-theme="dark"] .room__lightbox-close:focus-visible {
    background: var(--bg-2);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .room__three-nav button:hover,
  .room__three-nav button:focus-visible {
    background: rgba(252, 251, 248, 0.85);
  }

  :root[data-theme="dark"] .room__three-nav button:hover,
  :root[data-theme="dark"] .room__three-nav button:focus-visible {
    background: rgba(15, 15, 17, 0.85);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .room__theme-icon,
  .room__fullscreen-icon {
    display: inline-grid;
    place-items: center;
    line-height: 0;
  }

  [data-theme-icon="sun"] {
    display: none;
  }

  :root[data-theme="dark"] [data-theme-icon="moon"] {
    display: none;
  }

  :root[data-theme="dark"] [data-theme-icon="sun"] {
    display: inline-grid;
  }

  .room__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .room__viewstack,
  .room__view {
    min-height: 0;
    height: 100%;
  }

  .room__view {
    position: relative;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto auto;
    gap: 0.7rem;
  }

  .room__view--slider,
  .room__view--gallery {
    grid-template-rows: minmax(0, 1fr);
    padding: calc(var(--room-inset) + 3rem) 0 0;
    overflow: hidden;
  }

  .room__view--3d {
    grid-template-rows: minmax(0, 1fr);
  }

  .room__slider-inner {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 0.7rem;
    padding: var(--room-inset);
    box-shadow: inset 0 1px 0 0 var(--line-soft);
    overflow: hidden;
  }

  .room__view[hidden] {
    display: none;
  }

  .room__viewport {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--line-soft);
    background: var(--bg-0);
    min-height: 0;
  }

  :root[data-theme="dark"] .room__viewport {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      rgba(0, 0, 0, 0.24);
  }

  .room__three-wrap {
    position: relative;
    overflow: hidden;
    min-height: 100%;
  }

  .room__container {
    display: flex;
    gap: 1px;
    align-items: stretch;
    height: 100%;
    padding: 0;
  }

  .room__slide {
    flex: 0 0 auto;
    margin: 0;
    padding: 0;
  }

  .room__slide img {
    width: auto;
    height: 100%;
    max-width: none;
    border-radius: 0;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  .room__caption {
    margin: 0;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-1);
  }

  .room__hint {
    position: absolute;
    bottom: calc(var(--room-inset) + 0.6rem);
    left: 0;
    right: 0;
    z-index: 2;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink-0);
    justify-content: center;
    pointer-events: none;
    transition: opacity 1.2s ease;
  }

  .room__hint[hidden] {
    display: flex;
    opacity: 0;
  }

  .room__toolbar {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.65rem;
    padding-left: 0.35rem;
  }

  .room__controls {
    display: flex;
    gap: 0.5rem;
    justify-self: end;
  }

  .room__controls button {
    padding: 0.6rem;
    min-height: 2.4rem;
    min-width: 2.4rem;
    display: inline-grid;
    place-items: center;
    line-height: 0;
  }

  .room__three-canvas {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100%;
    touch-action: none;
  }

  .room__three-hint {
    position: absolute;
    bottom: calc(var(--room-inset) + 0.6rem);
    left: 0;
    right: 0;
    z-index: 2;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    mix-blend-mode: difference;
    pointer-events: none;
    transition: opacity 1.2s ease;
  }

  .room__three-hint[hidden] {
    display: flex;
    opacity: 0;
  }

  .room__three-nav {
    position: absolute;
    bottom: 0.8rem;
    right: 0.8rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: center;
  }

  .room__three-nav button {
    padding: 0.5rem;
    min-height: 2.2rem;
    min-width: 2.2rem;
    display: inline-grid;
    place-items: center;
    line-height: 0;
  }

  .room__zoom-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    border-radius: 999px;
    border: 1px solid var(--line-soft);
    background: rgba(252, 251, 248, 0.72);
    padding: 0.25rem 0;
    transition:
      background-color 160ms ease,
      border-color 160ms ease;
  }

  .room__zoom-group button {
    border: none;
    background: none;
    border-radius: 0;
  }

  :root[data-theme="dark"] .room__zoom-group {
    background: rgba(15, 15, 17, 0.72);
    border-color: rgba(255, 255, 255, 0.15);
  }

  :root[data-theme="dark"] .room__zoom-group button {
    background: none;
    border-color: transparent;
  }

  .room__zoom-slider {
    writing-mode: vertical-lr;
    direction: rtl;
    width: 2.2rem;
    height: 5rem;
    appearance: none;
    background: transparent;
    cursor: pointer;
    margin: 0;
  }

  .room__zoom-slider::-webkit-slider-runnable-track {
    width: 3px;
    background: var(--line-soft);
    border-radius: 2px;
  }

  .room__zoom-slider::-webkit-slider-thumb {
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ink-1);
    border: 1.5px solid var(--bg-0);
    margin-left: -4.5px;
  }

  .room__zoom-slider::-moz-range-track {
    width: 3px;
    background: var(--line-soft);
    border-radius: 2px;
  }

  .room__zoom-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ink-1);
    border: 1.5px solid var(--bg-0);
  }

  :root[data-theme="dark"] .room__zoom-slider::-webkit-slider-thumb {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(15, 15, 17, 0.72);
  }

  :root[data-theme="dark"] .room__zoom-slider::-moz-range-thumb {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(15, 15, 17, 0.72);
  }

  .room__three-loader {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    pointer-events: none;
    color: var(--ink-1);
  }

  .room__three-loader[hidden] {
    display: none;
  }

  .room__three-loader-text {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .room__spinner {
    width: 1.8rem;
    height: 1.8rem;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .room__gallery {
    overflow: auto;
    box-shadow: inset 0 1px 0 0 var(--line-soft);
  }

  .room__gallery-inner {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 52rem;
    margin-inline: auto;
    padding: var(--room-inset);
    gap: 0.8rem;
  }

  [data-fullscreen] .room__gallery-inner {
    max-width: 68rem;
  }

  .room__gallery-item {
