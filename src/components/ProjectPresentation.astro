<script>
  import "../scripts/room-loop";
  import "../scripts/theme-toggle";
  import "../scripts/project-presentation";

  const fsBtn = document.querySelector<HTMLButtonElement>("[data-fullscreen-toggle]");
  const presentation = document.querySelector<HTMLElement>("[data-presentation]");
  if (fsBtn && presentation && document.fullscreenEnabled) {
    fsBtn.addEventListener("click", () => {
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        document.documentElement.requestFullscreen();
      }
    });
    document.addEventListener("fullscreenchange", () => {
      const isFs = !!document.fullscreenElement;
      fsBtn.setAttribute("aria-label", isFs ? "Exit fullscreen" : "Enter fullscreen");
      if (isFs) {
        presentation.setAttribute("data-fullscreen", "");
      } else {
        presentation.removeAttribute("data-fullscreen");
      }
    });
  } else if (fsBtn) {
    fsBtn.style.display = "none";
  }
</script>
